// ═══════════════════════════════════════════════════════════════════════════
// firestore.rules — SIGA v2.0 · Pro Raça Rações
// ═══════════════════════════════════════════════════════════════════════════
//
// CONTROLE DE ACESSO BASEADO EM PAPEL (RBAC)
// O papel do usuário fica em users/{uid}.role no Firestore.
// Sem Custom Claims necessários.
//
// ── Papéis suportados ───────────────────────────────────────────────────────
//   admin       → acesso total (CRUD em tudo)
//   supervisor  → leitura total + escrita em ativos, manutenção, fornecedores,
//                 categorias, inventário, ordens, compras, documentos
//   operador    → leitura total + escrita operacional (criação de ordens,
//                 inspeções, inventário, ativos com restrições)
//   visualizador→ somente leitura
//
// ── Papéis legados (retrocompatibilidade com módulos HTML) ──────────────────
//   maintenance → equivale a supervisor
//   operations  → equivale a operador
//   purchasing  → equivale a supervisor (foco em compras/fornecedores)
//
// ── NOTAS IMPORTANTES ───────────────────────────────────────────────────────
//   • users: leitura pública permitida para o fluxo de login por código de
//     acesso (a query por accessCode ocorre ANTES da autenticação Firebase).
//     Este é um sistema interno sem URL pública — risco aceitável.
//   • isActive() checa o campo "active" (boolean). Ausência do campo = ativo.
//   • O campo é "active" no código React/TS, NÃO "ativo".
//
// ── DEPLOY ──────────────────────────────────────────────────────────────────
//   firebase deploy --only firestore:rules
//
// ── TESTE LOCAL ─────────────────────────────────────────────────────────────
//   firebase emulators:start --only firestore
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // FUNÇÕES AUXILIARES
    // ═══════════════════════════════════════════════════════════════════════

    // Usuário tem sessão Firebase ativa?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Lê o documento de perfil do usuário autenticado.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Retorna o papel do usuário (string).
    function getUserRole() {
      return getUserData().role;
    }

    // Usuário está ativo? Ausência do campo "active" é tratada como ativo.
    // IMPORTANTE: o campo no Firestore é "active" (booleano), não "ativo".
    function isActive() {
      let data = getUserData();
      return !('active' in data) || data.active != false;
    }

    // Usuário está autenticado E ativo?
    function isAuthAndActive() {
      return isAuthenticated() && isActive();
    }

    // ── Verificações de papel ────────────────────────────────────────────────

    // Somente admin.
    function isAdmin() {
      return isAuthAndActive() && getUserRole() == 'admin';
    }

    // Supervisor ou acima (inclui admin, maintenance, purchasing).
    function isSupervisor() {
      return isAuthAndActive() && getUserRole() in [
        'admin', 'supervisor', 'maintenance', 'purchasing'
      ];
    }

    // Operador ou acima (inclui supervisor).
    function isOperador() {
      return isAuthAndActive() && getUserRole() in [
        'admin', 'supervisor', 'operador',
        'maintenance', 'operations', 'purchasing'
      ];
    }

    // Qualquer papel válido pode ler dados compartilhados.
    function isAnyRole() {
      return isAuthAndActive() && getUserRole() in [
        'admin', 'supervisor', 'operador', 'visualizador',
        'maintenance', 'operations', 'purchasing'
      ];
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USERS
    // ═══════════════════════════════════════════════════════════════════════
    //
    // LEITURA PÚBLICA INTENCIONAL:
    //   O fluxo de login busca o documento pelo campo "accessCode" ANTES de
    //   o usuário estar autenticado no Firebase Auth. Sem essa permissão, o
    //   login por código de acesso nunca funciona.
    //   Sistema interno → risco aceitável.
    //
    match /users/{userId} {
      // Leitura aberta: necessária para o login por accessCode (pré-auth).
      allow read: if true;

      // Criação e exclusão: apenas admin.
      allow create: if isAdmin();
      allow delete: if isAdmin();

      // Update:
      //   • Admin altera qualquer campo.
      //   • O próprio usuário pode atualizar somente campos de sessão.
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastLogin', 'lastSeen']))
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PATRIMÔNIO — Categorias de Ativos
    // ═══════════════════════════════════════════════════════════════════════
    match /asset_categories/{catId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PATRIMÔNIO — Ativos
    // ═══════════════════════════════════════════════════════════════════════
    match /assets/{assetId} {
      allow read:   if isAnyRole();

      // Operadores registram ativos.
      allow create: if isOperador();

      // Supervisor altera qualquer campo.
      // Operador não pode trocar categoria, código ou prefixo.
      allow update: if isSupervisor() || (
        isOperador() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['categoryId', 'code', 'codePrefix'])
      );

      // Exclusão é destrutiva → somente admin.
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PATRIMÔNIO — Histórico de Eventos de Ativos (asset_events)
    // ═══════════════════════════════════════════════════════════════════════
    match /asset_events/{eventId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Eventos são auditoria imutável — update bloqueado para todos.
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PATRIMÔNIO — Manutenção de Ativos
    // ═══════════════════════════════════════════════════════════════════════
    match /asset_maintenance/{maintId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PATRIMÔNIO — Fornecedores de Ativos
    // ═══════════════════════════════════════════════════════════════════════
    match /asset_suppliers/{suppId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PATRIMÔNIO — Sessões de Inventário
    // ═══════════════════════════════════════════════════════════════════════
    match /inventory_sessions/{sessionId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OPERAÇÕES — Ordens de Serviço (work_orders)
    // ═══════════════════════════════════════════════════════════════════════
    match /work_orders/{woId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();

      // Supervisor altera status/prioridade; operador atualiza outros campos.
      allow update: if isSupervisor() || (
        isOperador() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['status', 'prioridade', 'priority'])
      );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COMPRAS — Pedidos de Compra (purchase_orders)
    // ═══════════════════════════════════════════════════════════════════════
    match /purchase_orders/{poId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();

      // Supervisor aprova/rejeita; operador atualiza campos não-sensíveis.
      allow update: if isSupervisor() || (
        isOperador() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['status', 'aprovadoPor', 'rejeitadoPor', 'approvedBy'])
      );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DOCUMENTOS — Documentos de OS/Compras gerados pelo React (order_documents)
    // ═══════════════════════════════════════════════════════════════════════
    match /order_documents/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Documento gerado é imutável; supervisor corrige se necessário.
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DOCUMENTOS — Documentos formais de compras (purchase_document) [legacy]
    // ═══════════════════════════════════════════════════════════════════════
    match /purchase_document/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DOCUMENTOS — Documentos formais SRV + PO (módulo os/) [legacy]
    // ═══════════════════════════════════════════════════════════════════════
    match /documents/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OPERAÇÕES — Relatórios de Serviço [legacy]
    // ═══════════════════════════════════════════════════════════════════════
    match /service_report/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Relatório fechado: supervisor corrige; operador não altera.
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OPERAÇÕES — Histórico de Manutenção [legacy]
    // ═══════════════════════════════════════════════════════════════════════
    match /historico_manutencao/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FACILITIES — Inspeções de Limpeza (cleaning_inspections) [principal]
    // ═══════════════════════════════════════════════════════════════════════
    match /cleaning_inspections/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FACILITIES — Limpeza singular [alias legado]
    // ═══════════════════════════════════════════════════════════════════════
    match /cleaning_inspection/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FACILITIES — Auditorias de Limpeza [legacy HTML]
    // ═══════════════════════════════════════════════════════════════════════
    match /auditorias_limpeza/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FROTA — Checklists de Inspeção de Veículos
    // ═══════════════════════════════════════════════════════════════════════
    match /checklists_frota/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Atualização inclui backlinks para WO/PO após submissão.
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FROTA — Estado dos Veículos (KPI cache por veículo)
    // ═══════════════════════════════════════════════════════════════════════
    match /vehicle_state/{vehicleId} {
      allow read:   if isAnyRole();
      // setDoc com merge:true → cobre create e update.
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // MAQUINÁRIO — Estado das Máquinas
    // ═══════════════════════════════════════════════════════════════════════
    match /machine_state/{machineId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // MAQUINÁRIO — Inspeções de Máquinas
    // ═══════════════════════════════════════════════════════════════════════
    match /machine_inspections/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Supervisor valida/corrige inspeções.
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FORNECEDORES — Coleção legacy (módulos HTML compras/ativos)
    // ═══════════════════════════════════════════════════════════════════════
    match /fornecedores/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OBRAS — Registro de Obras Terceirizadas
    // ═══════════════════════════════════════════════════════════════════════
    match /obras/{obraId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OBRAS — Empreiteiras Cadastradas
    // ═══════════════════════════════════════════════════════════════════════
    match /empreiteiras/{empId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OBRAS — Inspeções de Obra
    // ═══════════════════════════════════════════════════════════════════════
    match /inspecoes_obra/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Supervisor pode aprovar/validar inspeções
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OBRAS — Avaliações Finais de Empreiteiras
    // ═══════════════════════════════════════════════════════════════════════
    match /avaliacoes_empreiteira/{docId} {
      allow read:   if isAnyRole();
      // Avaliação final exige nível supervisor
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OBRAS — Timeline (CIP V1 — Digital Twin básico, escrita direta do client)
    // ═══════════════════════════════════════════════════════════════════════
    match /obra_timeline/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Timeline é histórico — update bloqueado para todos.
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OBRAS — Documentação (CIP V2 — contrato, aditivos, ART, seguro, etc.)
    // ═══════════════════════════════════════════════════════════════════════
    match /obra_documentos/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isSupervisor();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — DDS (Diálogo Diário de Segurança)
    // ═══════════════════════════════════════════════════════════════════════
    match /safety_dds/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — DDI (Inspeção Diária de Segurança)
    // ═══════════════════════════════════════════════════════════════════════
    match /safety_ddi/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — Fichas de EPI por Colaborador
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_epi/{fichaId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — Inspeções de EPI
    // ═══════════════════════════════════════════════════════════════════════
    match /epi_inspections/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — Ocorrências e Incidentes
    // ═══════════════════════════════════════════════════════════════════════
    match /safety_occurrences/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Qualquer operador pode atualizar (para fechar/investigar ocorrências).
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — Permissões de Trabalho
    // ═══════════════════════════════════════════════════════════════════════
    match /work_permits/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      // Aprovação de permissão exige supervisor.
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — Ações e Planos de Ação de Segurança
    // ═══════════════════════════════════════════════════════════════════════
    match /safety_actions/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SEGURANÇA — KPI de Segurança (snapshots mensais)
    // ═══════════════════════════════════════════════════════════════════════
    match /safety_kpi/{docId} {
      allow read:  if isAnyRole();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Master record de funcionários
    // ═══════════════════════════════════════════════════════════════════════
    match /employees/{empId} {
      allow read:   if isAnyRole();
      // Supervisor cria e atualiza. Operador pode atualizar contadores (safety integration).
      allow create: if isSupervisor();
      allow update: if isSupervisor() || (
        isOperador() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['nome', 'matricula', 'cpf', 'rg', 'cargo', 'departamento', 'nivelAcesso'])
      );
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Histórico de Eventos (timeline)
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_history/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Avaliações de Desempenho
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_evaluations/{docId} {
      allow read:   if isAnyRole();
      // Avaliação exige supervisor
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Advertências
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_warnings/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      // Atualização para resolver advertência
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Banco de Horas
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_timebank/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Registros de Ponto (Banco de Horas v2)
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_timebank_registros/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Reconhecimentos
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_recognitions/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Notas do Supervisor
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_supervisor_notes/{docId} {
      allow read:   if isSupervisor();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Histórico de Departamentos / Movimentações
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_department_history/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Cache de Dashboard RH
    // ═══════════════════════════════════════════════════════════════════════
    match /employee_dashboard_cache/{docId} {
      allow read:  if isAnyRole();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DASHBOARD — Cache de KPIs do painel principal (React)
    // Escrito client-side por computeAndWriteKpiCache em db-dashboard.ts.
    // Qualquer operador pode atualizar; visualizador só lê o cache existente.
    // ═══════════════════════════════════════════════════════════════════════
    match /dashboard_kpi_cache/{docId} {
      allow read:  if isAnyRole();
      allow write: if isOperador();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // KPI CACHE — Cache legado / por Cloud Function (service account)
    // ═══════════════════════════════════════════════════════════════════════
    match /kpi_cache/{docId} {
      allow read:  if isAnyRole();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CONTROLE DE ACESSO — Logs de Auditoria (access_logs)
    // ═══════════════════════════════════════════════════════════════════════
    //   • Somente admins leem o histórico completo.
    //   • Qualquer usuário autenticado pode gravar (login, role change, etc.)
    //   • Logs são imutáveis (update bloqueado).
    //   • Admin pode apagar logs antigos.
    match /access_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // PATRIMÔNIO — Histórico de Localização de Ativos (asset_location_history)
    // ═══════════════════════════════════════════════════════════════════════
    match /asset_location_history/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Documentos de RH (subcoleção de employees)
    // ═══════════════════════════════════════════════════════════════════════
    match /employees/{empId}/employee_documents/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CD — Inventário de Insumos (contagens)
    // ═══════════════════════════════════════════════════════════════════════
    match /contagens_insumos/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CD — Catálogo de Insumos (config/insumos_lista)
    // ═══════════════════════════════════════════════════════════════════════
    match /config/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CD — Contadores Sequenciais (meta/contagens_insumos_counter)
    // ═══════════════════════════════════════════════════════════════════════
    match /meta/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CD — Rascunhos de Edição (auto-save por usuário, docId = {uid}__*)
    // ═══════════════════════════════════════════════════════════════════════
    match /rascunhos_edicao/{docId} {
      allow read, write: if isAuthAndActive() &&
        docId.split('__')[0] == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CD — Log de Auditoria (cd_audit_log)
    // ═══════════════════════════════════════════════════════════════════════
    match /cd_audit_log/{docId} {
      allow read:   if isSupervisor();
      allow create: if isAuthAndActive();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // COLABORADORES — Avaliações KPI (54 indicadores · sistema de desempenho)
    // ═══════════════════════════════════════════════════════════════════════
    match /kpi_evaluations/{docId} {
      allow read:   if isAnyRole();
      allow create: if isSupervisor();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ═══════════════════════════════════════════════════════════════════════
    // ROADMAP — Templates de Jornada do Colaborador
    // ═══════════════════════════════════════════════════════════════════════
    match /roadmap_templates/{docId} {
      allow read:   if isAnyRole();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ROADMAP — Auditoria de alterações de etapas (subcoleção do employee)
    // ═══════════════════════════════════════════════════════════════════════
    match /employees/{empId}/roadmap_audit/{docId} {
      allow read:   if isSupervisor();
      allow create: if isSupervisor();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // OUVIDORIA — Manifestações (criação pública anônima, sem leitura direta)
    // ═══════════════════════════════════════════════════════════════════════
    match /manifestacoes/{docId} {
      allow create: if
        request.resource.data.keys().hasAll([
          'protocolo', 'unidade', 'assunto', 'descricao',
          'anonimo', 'status', 'dataCriacao', 'origem'
        ]) &&
        request.resource.data.protocolo is string &&
        request.resource.data.protocolo.size() > 0 &&
        request.resource.data.descricao is string &&
        request.resource.data.descricao.size() >= 20 &&
        request.resource.data.descricao.size() <= 3000 &&
        request.resource.data.unidade is string &&
        request.resource.data.unidade.size() > 0 &&
        request.resource.data.assunto is string &&
        request.resource.data.assunto.size() > 0 &&
        request.resource.data.anonimo is bool &&
        request.resource.data.status == 'Nova' &&
        request.resource.data.origem in ['online', 'offline'];
      allow read:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // OUVIDORIA — Contadores de protocolo (leitura/escrita pública, sem delete)
    // ═══════════════════════════════════════════════════════════════════════
    match /contadores/{docId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DATA HUB — Snapshot de Inteligência Operacional (data_hub_snapshots)
    // Gerado client-side; documento único 'latest'; TTL 30 min.
    // Qualquer operador pode reescrever (para forçar refresh do hub).
    // ═══════════════════════════════════════════════════════════════════════
    match /data_hub_snapshots/{docId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isOperador();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // EAM — Custos de Ativo (asset_costs)
    // Registro de todos os custos associados a um ativo patrimonial.
    // Supervisor pode criar/atualizar; admin exclui.
    // ═══════════════════════════════════════════════════════════════════════
    match /asset_costs/{costId} {
      allow read:   if isAnyRole();
      allow create: if isOperador();
      allow update: if isSupervisor();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // AUDITORIA GLOBAL — Log imutável de todas as ações do sistema (audit_log)
    //   • Supervisor+ pode ler o histórico completo.
    //   • Qualquer usuário autenticado e ativo pode gravar.
    //   • Logs são imutáveis (update bloqueado).
    //   • Admin pode apagar logs antigos por política de retenção.
    // ═══════════════════════════════════════════════════════════════════════
    match /audit_log/{logId} {
      allow read:   if isSupervisor();
      allow create: if isAuthAndActive();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CATCH-ALL — Nega tudo que não foi explicitamente permitido acima.
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
